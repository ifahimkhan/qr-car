# Copy this file to .env and fill in real values. Never commit .env to git.

# PostgreSQL connection string (required for production — SQLite won't work on Vercel)
# Free options: https://neon.tech  |  https://supabase.com  |  https://railway.app
DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require

# Twilio — get from twilio.com/console
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_PHONE_NUMBER=+1xxxxxxxxxx
TWILIO_WHATSAPP_FROM=+14155238886

# JWT — generate a strong secret: openssl rand -hex 32
JWT_SECRET=replace_with_32_plus_char_random_string

# Your production domain (no trailing slash). Used for QR code URLs.
# On Vercel this is: https://your-project.vercel.app
NEXT_PUBLIC_BASE_URL=https://your-project.vercel.app
NEXT_PUBLIC_TWILIO_NUMBER=+1xxxxxxxxxx
